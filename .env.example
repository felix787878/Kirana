# Salin ke .env.local dan isi nilai dari Firebase Console (Project settings).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Opsional (Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Server-only: Google AI Studio / Gemini API (untuk /api/roadmap)
# Buat kunci di https://aistudio.google.com/apikey — pakai "Google AI Studio", bukan Vertex saja.
GEMINI_API_KEY=
# Alias opsional jika kamu sudah memakai nama ini di proyek lain:
# GOOGLE_GENERATIVE_AI_API_KEY=
# Opsional: paksa model (jika default gagal 404), contoh: gemini-2.0-flash
# GEMINI_MODEL=
