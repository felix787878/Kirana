# Salin ke .env.local dan isi nilai dari Firebase Console (Project settings).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Opsional (Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Server-only: OpenRouter (untuk /api/roadmap) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Opsional: paksa model, contoh: openai/gpt-4o-mini — daftar: https://openrouter.ai/models
# OPENROUTER_MODEL=
# Opsional: URL penuh ke chat completions (default: https://openrouter.ai/api/v1/chat/completions)
# OPENROUTER_BASE_URL=
# Opsional: untuk ranking OpenRouter
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=
